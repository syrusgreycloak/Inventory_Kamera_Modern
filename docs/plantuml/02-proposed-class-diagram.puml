@startuml Proposed Architecture - Class Diagram (Milestone 1)

title Milestone 1 Target Architecture - Abstracted & Testable
note as N1
  **Improvements:**
  - .NET 8 migration (net8.0-windows for WinForms)
  - Platform-agnostic Core library
  - Interface-based abstractions
  - Accord.Imaging removed (replaced by ImageSharp)
  - System.Drawing removed from Core
  - External configuration
  - Testable business logic
end note

package "InventoryKamera.Core" <<Cloud>> {
  note top of InventoryKamera.Core
    .NET 8 Class Library (no -windows suffix)
    No WinForms/System.Drawing dependencies
    Cross-platform compatible
  end note

  package "Models" {
    class Character {
      + Name : string
      + Level : int
      + Constellation : int
      + Weapon : Weapon
      + Artifacts : Artifact[]
    }

    class Weapon {
      + Name : string
      + Level : int
      + Refinement : int
      + Rarity : int
      + EquippedCharacter : string
    }

    class Artifact {
      + SetName : string
      + Slot : string
      + Level : int
      + Rarity : int
      + MainStat : Stat
      + SubStats : List<Stat>
      + EquippedCharacter : string
      + Locked : bool
    }

    class Inventory {
      + Weapons : List<Weapon>
      + Artifacts : List<Artifact>
      + Materials : List<Material>
    }

    class GOOD {
      + Export(Inventory) : string
      {note: System.Text.Json or Newtonsoft.Json}
    }
  }

  package "Abstractions" {
    interface IScreenCapture {
      + CaptureRegion(Rectangle) : Bitmap
      + CaptureWindow() : Bitmap
      + GetWindowSize() : Size
      + GetWindowPosition() : Point
      {note: Milestone 1: System.Drawing.Bitmap\nMilestone 2+: ImageSharp IImage abstraction}
    }

    interface IInputSimulator {
      + Click() : void
      + SetCursor(int, int) : void
      + KeyPress(VirtualKeyCode) : void
      + ScrollDown(int) : void
      {note: Windows/macOS/Linux specific}
    }

    interface IImageProcessor {
      + Crop(Bitmap, Rectangle) : Bitmap
      + GetPixel(Bitmap, int, int) : Color
      + ApplyGrayscale(Bitmap) : Bitmap
      + ApplyThreshold(Bitmap, int) : Bitmap
      + ApplyContrast(Bitmap, double) : Bitmap
      {note: Milestone 1: wraps ImageSharp\nBitmap params replaced by IImage when\nSystem.Drawing is fully removed}
    }

    interface IOcrEngine {
      + Recognize(Bitmap, PageSegMode) : string
      {note: Tesseract wrapper\nMilestone 1: synchronous — cooperative\ncancellation via CancellationTokenSource\nis sufficient, full async not required}
    }

    interface IUserInterface {
      + SetWeaponMax(int) : void
      + IncrementWeapon(int) : void
      + SetArtifactMax(int) : void
      + IncrementArtifact(int) : void
      + UpdatePreview(Bitmap) : void
      + AddLogMessage(string) : void
      + SetStatus(string) : void
    }
  }

  package "Configuration" {
    class ScanProfile {
      + Version : string
      + AspectRatio : double
      + Artifacts : ArtifactRegions
      + Weapons : WeaponRegions
      + Characters : CharacterRegions
    }

    class ArtifactRegions {
      + Card : Rectangle
      + Name : Rectangle
      + Substats : Rectangle
      + SanctifyIndicator : Rectangle
      + SanctifyShift : double
      {note: Loaded from ScanProfile.json}
    }

    class ScanProfileManager {
      - profiles : Dictionary<string, ScanProfile>
      + LoadProfiles(string) : void
      + GetProfile(double) : ScanProfile
      + DetectResolution(Size) : ScanProfile
      {note: Manages resolution profiles}
    }

    class DataSourceConfig {
      + RepositoryUrl : string
      + Endpoints : Dictionary<string, string>
      + FallbackRepositories : List<Repository>
      {note: From datasources.json (Phase 1)}
    }
  }

  package "Scanning" {
    interface IArtifactScraper {
      + ScanArtifactsAsync(IProgress, CancellationToken) : Task<List<Artifact>>
      + CatalogueAsync(IImage, CancellationToken) : Task<Artifact>
    }

    class ArtifactScraper {
      - screenCapture : IScreenCapture
      - imageProcessor : IImageProcessor
      - ocrEngine : IOcrEngine
      - scanProfile : ScanProfile
      + ScanArtifacts(CancellationToken) : List<Artifact>
      - IsSanctified(Bitmap) : bool
      - GetSubstatsRegion(bool) : Rectangle
      {note: Uses injected dependencies\nCancellationToken for cooperative shutdown\n(check IsCancellationRequested in loops)}
    }

    class OcrEnginePool {
      - engines : ConcurrentBag<IOcrEngine>
      - maxEngines : int
      + BorrowEngine() : IOcrEngine
      + ReturnEngine(IOcrEngine) : void
      {note: Thread-safe pool management}
    }

    class ScanOrchestrator {
      - artifactScraper : IArtifactScraper
      - weaponScraper : IWeaponScraper
      - characterScraper : ICharacterScraper
      - materialScraper : IMaterialScraper
      + ScanAllAsync(ScanOptions, IProgress, CancellationToken) : Task<Inventory>
      {note: Coordinates multi-category scanning\nPropagates CancellationToken to all scrapers}
    }

    class ScanProgress {
      + Current : int
      + Total : int
      + CurrentItem : string
      + Status : ScanStatus
      + Errors : List<ScanError>
      {note: Progress reporting with error tracking}
    }
  }

  package "Data" {
    class DatabaseManager {
      - httpClient : HttpClient
      - config : DataSourceConfig
      + UpdateAllAsync() : Task
      - UpdateCharactersAsync() : Task
      - UpdateArtifactsAsync() : Task
      {note: No UI dependencies}
    }

    class GenshinDataProcessor {
      + Mappings : Dictionary<ulong, string>
      + UpdateCharacterName(string, string) : void
      + ParseCharacterData(JsonElement) : Character
      {note: Pure JSON processing}
    }
  }

  ' Relationships within Core
  ArtifactScraper ..|> IArtifactScraper
  ArtifactScraper --> IScreenCapture : uses
  ArtifactScraper --> IImageProcessor : uses
  ArtifactScraper --> IOcrEngine : uses
  ArtifactScraper --> ScanProfile : reads regions

  ScanOrchestrator --> IArtifactScraper : orchestrates
  ScanOrchestrator --> Inventory : builds

  OcrEnginePool --> IOcrEngine : manages

  ScanProfileManager --> ScanProfile : loads/provides
  DatabaseManager --> DataSourceConfig : uses
  DatabaseManager --> GenshinDataProcessor : uses

  Inventory *-- Weapon
  Inventory *-- Artifact
  Character --> Weapon
  Character --> Artifact

  GOOD --> Inventory : exports
}

package "InventoryKamera.Infrastructure" <<Cloud>> {
  note top of InventoryKamera.Infrastructure
    .NET 8 Class Library
    Platform-specific implementations
    References: ImageSharp, Tesseract
    Note: Accord.Imaging 3.8.0 (abandoned 2018)
    removed here — was coupled to System.Drawing,
    both replaced together by ImageSharp
  end note

  package "Windows" {
    class WindowsScreenCapture {
      + CaptureRegion(Rectangle) : Bitmap
      + CaptureWindow() : Bitmap
      + GetWindowSize() : Size
      + GetWindowPosition() : Point
      {note: Graphics.CopyFromScreen wrapper\nDelegate to Navigation initially,\nthen migrate logic incrementally}
    }

    class WindowsInputSimulator {
      + SendKey(KeyCode) : void
      + SendMouseClick(int, int) : void
      {note: Uses WindowsInput library}
    }
  }

  package "ImageSharp" {
    class ImageSharpProcessor {
      + Crop(IImage, Rectangle) : IImage
      + GetPixel(IImage, int, int) : Color
      + ApplyGrayscale(IImage) : IImage
      {note: Wraps SixLabors.ImageSharp}
    }

    class ImageSharpImage {
      - image : Image<Rgba32>
      + Width : int
      + Height : int
      + GetBytes() : byte[]
      {note: Implements IImage}
    }
  }

  package "Tesseract" {
    class TesseractOcrEngine {
      - engine : TesseractEngine
      + Recognize(Bitmap, PageSegMode) : string
      {note: Wraps Tesseract 5.2.0 or TesseractOCR 5.5.2\n(evaluate in Milestone 1 Step 1.3)}
    }
  }

  ' Infrastructure implements Core abstractions
  WindowsScreenCapture ..|> IScreenCapture
  WindowsInputSimulator ..|> IInputSimulator
  ImageSharpProcessor ..|> IImageProcessor
  TesseractOcrEngine ..|> IOcrEngine
}

package "InventoryKamera (WinForms)" <<Rectangle>> {
  note top of InventoryKamera
    net8.0-windows — migrated in Milestone 1
    References Core + Infrastructure
    Deprecated in Milestone 2 (replaced by Avalonia)
  end note

  class MainForm {
    - serviceProvider : IServiceProvider
    - scanOrchestrator : ScanOrchestrator
    + StartScan() : void
    + UpdateProgress(ScanProgress) : void
    {note: Adapted to use Core library}
  }

  class ServiceProviderFactory <<static>> {
    + {static} CreateProvider() : IServiceProvider
    {note: Registers Core + Infrastructure services}
  }

  MainForm ..> ServiceProviderFactory : creates
  MainForm --> ScanOrchestrator : uses
}

package "InventoryKamera.Tests" <<Cloud>> {
  note top of InventoryKamera.Tests
    .NET 8 xUnit Test Project
    References Core only (not Infrastructure)
    Uses mock implementations
  end note

  class MockScreenCapture {
    - testDataPath : string
    + CaptureRegion(Rectangle) : Bitmap
    + CaptureWindow() : Bitmap
    {note: Loads pre-captured test images from disk}
  }

  class MockOcrEngine {
    - mockResults : Dictionary<string, string>
    + Recognize(Bitmap, PageSegMode) : string
    {note: Returns pre-defined test results}
  }

  class ArtifactScraperTests {
    + ScanSanctifiedArtifact_AppliesCorrectShift()
    + ScanRegularArtifact_NoShift()
    + DetectPurpleColor_LightAndDarkVariants()
  }

  MockScreenCapture ..|> IScreenCapture
  MockOcrEngine ..|> IOcrEngine
  ArtifactScraperTests --> MockScreenCapture : uses
  ArtifactScraperTests --> MockOcrEngine : uses
  ArtifactScraperTests --> ArtifactScraper : tests
}

' Cross-package relationships
MainForm --> ScanOrchestrator : uses (via DI)
ServiceProviderFactory ..> WindowsScreenCapture : registers
ServiceProviderFactory ..> ImageSharpProcessor : registers
ServiceProviderFactory ..> TesseractOcrEngine : registers

note bottom of ServiceProviderFactory
  **Dependency Injection (Milestone 1 — WinForms):**
  services.AddSingleton<IScreenCapture, WindowsScreenCapture>();
  services.AddSingleton<IInputSimulator, WindowsInputSimulator>();
  services.AddSingleton<IImageProcessor, ImageSharpProcessor>();
  services.AddSingleton<IOcrEngine, OcrEnginePool>();
  services.AddSingleton<IUserInterface, WinFormsUserInterface>();
  services.AddTransient<ArtifactScraper>();
end note

note bottom of ScanProfile
  **External Configuration:**
  Loaded from ScanProfile.json
  No hard-coded coordinates in code
  Users can create custom profiles
end note

note bottom of ImageSharpProcessor
  **Cross-Platform:**
  Works on Windows, macOS, Linux
  No System.Drawing dependency
  Native performance
end note

@enduml
